{
    "name": "order-report-legacy",
    "version": "1.0.0",
    "description": "Legacy order report system - Refactoring test",
    "main": "legacy/orderReportLegacy.ts",
    "scripts": {
        "legacy": "ts-node legacy/orderReportLegacy.ts",
        "start": "ts-node -r tsconfig-paths/register src/main.ts",
        "test": "pnpm test:unit && pnpm test:golden",
        "test:unit": "jest --testPathIgnorePatterns=golden.master",
        "test:golden": "jest tests/golden.master.test.ts",
        "test:watch": "jest --watch",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/jest": "^29.5.0",
        "@types/node": "^20.0.0",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "jest": "^29.5.0",
        "prettier": "^3.8.2",
        "ts-jest": "^29.1.0",
        "ts-node": "^10.9.0",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.58.1"
    }
}
